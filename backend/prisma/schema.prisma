// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id      String    @id @default(uuid())
  profile Profile[]

  email    String @unique
  username String @db.VarChar(200)
  password String @db.VarChar(255)
  role     Role   @default(USER)

  // Later enum of roles would be added => To let user have different permissions

  isEmailVerified Boolean @default(false)
  isActive        Boolean @default(false) // Later shall be removed => To let user use from different browsers at the same time
  tokenVersion    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Profile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  name     String  @unique
  isActive Boolean @default(false)

  bio       String?
  avatarUrl String? // Later changed to required
  cloudId   String?

  isPrivate Boolean @default(false)

  posts         Post[]
  story         Story?
  reels         Reel[]
  savedPosts    SavePost[]
  storiesViewed StoryViews[]

  job Job[]

  receivedNotifications Notification[] @relation("Receiver")

  followers  Follow[] @relation("followers")
  followings Follow[] @relation("followings")

  pofileLikes      Likes[]
  profileCommentes Comments[]

  chats ChatMember[]
  admin Chat[]       @relation("ChatCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Follow {
  id String @id @default(uuid())

  followerId  String
  followingId String

  createdAt DateTime @default(now())

  follower  Profile @relation("followings", fields: [followerId], references: [id], onDelete: Cascade)
  following Profile @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Post {
  id String @id @default(uuid())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  isReady Boolean @default(false) // Later be removed

  caption     String
  description String?
  postPhoto   PostMedia[]

  notify Notification[] @relation("PostNotify")

  likes    Likes[]
  comments Comments[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostMedia {
  id     String @id @default(uuid())
  postId String

  mediaUrl String
  cloudId  String

  savedPosts SavePost[]

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model SavePost {
  id          String @id @default(uuid())
  postMediaId String

  profileId String // It is id of the user who saves

  post    PostMedia @relation(fields: [postMediaId], references: [id], onDelete: Cascade)
  profile Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Reel {
  id String @id @default(uuid())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  videoUrl String
  cloudId  String
  caption  String?

  likes    Likes[]
  comments Comments[]

  notify Notification[] @relation("ReelNotify")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Story {
  id String @id @default(uuid())

  profileId String  @unique
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  isReady   Boolean  @default(false) // Later be removed => And have One to Many with Jobs

  storyMedia StoryMedia[]

  notify Notification[] @relation("StoryNotify")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Media {
  IMG
  VIDEO
  COMBINED
}

model StoryMedia {
  id      String @id @default(uuid())
  storyId String

  mediaUrl  String
  cloudId   String
  mediaType Media
  order     Int    @default(0)

  duration Int @default(3) // Only for video, for image it will be 0

  storyViews StoryViews[]
  likes      Likes[]

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model StoryViews {
  id String @id @default(uuid())

  storyMediaId String
  storyMedia   StoryMedia @relation(fields: [storyMediaId], references: [id], onDelete: Cascade)

  viewerId String
  viewer   Profile @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storyMediaId, viewerId]) // To prevent multiple views marking
}

model Likes {
  id String @id @default(uuid())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  postId String?
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)

  reelId String?
  reel   Reel?   @relation(fields: [reelId], references: [id], onDelete: Cascade)

  storyMediaId String?
  storyMedia   StoryMedia? @relation(fields: [storyMediaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([profileId, postId])
  @@unique([profileId, reelId])
  @@unique([profileId, storyMediaId])
}

model Comments {
  id String @id @default(uuid())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  postId String?
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)

  reelId String?
  reel   Reel?   @relation(fields: [reelId], references: [id], onDelete: Cascade)

  replies Comments[] @relation("CommentToComment") // to handle reply 

  parentId      String?
  parentComment Comments? @relation("CommentToComment", fields: [parentId], references: [id], onDelete: Cascade)

  content String

  createdAt DateTime @default(now())
}

enum Purpose {
  COMMENT
  POST
  REEL
  STORY
  CHAT
  MESSAGE
}

model Notification {
  id String @id @default(uuid())

  receiverId String
  receiver Profile @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  // This 2 below only would be sent to client with notification
  purpose Purpose
  content String

  // After making them as isRead true => these id would be sent in return 
  storyId   String?
  postId    String?
  reelId    String?
  chatId    String?

  story   Story?   @relation("StoryNotify", fields: [storyId], references: [id], onDelete: Cascade)
  post    Post?    @relation("PostNotify", fields: [postId], references: [id], onDelete: Cascade)
  reel    Reel?    @relation("ReelNotify", fields: [reelId], references: [id], onDelete: Cascade)
  chat    Chat?    @relation("NewChatNotify", fields: [chatId], references: [id], onDelete: Cascade)

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([receiverId])
}

enum JobName {
  STORY
  POST
}

enum JobStatus {
  PROGRESS
  SUCCESS
  FAILED
  CANCELLED
}

model Job {
  id String @id @default(uuid())

  jobId  String @unique
  name   JobName
  status JobStatus

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  storyId String?
  postId  String?

  createdAt DateTime @default(now())
}

enum ChatType {
  PRIVATE
  GROUP
}

model Chat {
  id String @id @default(uuid())

  name     String?
  mediaUrl String?
  cloudId  String?

  creatorId String
  creator   Profile @relation("ChatCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  type ChatType

  notify  Notification[] @relation("NewChatNotify")
  members ChatMember[]
  message Message[]

  createdAt DateTime @default(now())
}

model ChatMember {
  id        String @id @default(uuid())
  chatId    String
  profileId String
  chat      Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  isApproved Boolean @default(false)

  message Message[]
  views   MessageView[]

  createdAt DateTime @default(now())

  @@unique([chatId, profileId])
}

enum Format {
  TEXT
  FILE
  VIDEO
  GIF
  IMAGE
}

model Message {
  id String @id @default(uuid())

  format   Format  @default(TEXT)
  content  String?
  mediaUrl String?
  cloudId  String?

  senderId String
  sender   ChatMember @relation(fields: [senderId], references: [id], onDelete: Cascade)

  replyId String?
  reply   Message?  @relation("MessageReply", fields: [replyId], references: [id], onDelete: Cascade)
  replyTo Message[] @relation("MessageReply")

  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  msgView MessageView[]
  createdAt DateTime @default(now())

  @@index([chatId])
}

model MessageView {
  id       String @id @default(uuid())
  memberId String

  msgId    String
  member   ChatMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  message  Message    @relation(fields: [msgId], references: [id], onDelete: Cascade)
  viewedAt DateTime   @default(now())

  @@unique([msgId, memberId])
}
