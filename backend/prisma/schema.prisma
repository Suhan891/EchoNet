// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id      String    @id @default(uuid())
  profile Profile[] // is 0-Many

  email    String @unique
  username String @db.VarChar(200)
  password String @db.VarChar(255)
  role     Role   @default(USER)

  // Also add enum of :role:

  isEmailVerified Boolean @default(false)
  isActive        Boolean @default(false) // Later shall be removed => To let user use from different browsers at the same time
  tokenVersion Int @default(0)

  passResetToken   String? // Shall be removed
  passResetExpTime DateTime?  // Shall be removed

  jobs Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Profile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  name     String  @unique
  isActive Boolean @default(false)

  bio       String?
  avatarUrl String?  // Later changed to required
  cloudId   String?

  isPrivate Boolean @default(false)

  posts         Post[]
  story         Story?
  reels         Reel[]
  savedPosts    SavePost[]
  storiesViewed StoryViews[]

  sentNotifications     Notification[] @relation("Sender")
  receivedNotifications Notification[] @relation("Receiver")

  followers  Follow[] @relation("followers")
  followings Follow[] @relation("followings")

  // Whenever this profile likes other post, reel, story media or writes comment
  pofileLikes      Likes[]
  profileCommentes Comments[]

  // Job id shall be stored in Job table with the user id and job name to track the progress of the job

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Follow {
  id String @id @default(uuid())

  followerId  String
  followingId String

  createdAt DateTime @default(now())

  follower  Profile @relation("followings", fields: [followerId], references: [id])
  following Profile @relation("followers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Post {
  id String @id @default(uuid())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  isReady Boolean @default(false)
  
  caption   String
  description String?
  postPhoto PostMedia[]

  likes    Likes[]
  comments Comments[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostMedia {
  id     String @id @default(uuid())
  postId String

  mediaUrl String
  cloudId  String

  savedPosts SavePost[]

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model SavePost {
  id          String @id @default(uuid())
  postMediaId String

  profileId String // It will be the id of the user who saves

  post    PostMedia @relation(fields: [postMediaId], references: [id], onDelete: Cascade)
  profile Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Reel {
  id String @id @default(uuid())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id])

  videoUrl String
  cloudId  String
  caption  String?

  likes    Likes[]
  comments Comments[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Story {
  id String @id @default(uuid())

  profileId String  @unique
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  isReady Boolean @default(false) // Later be removed => And have One to Many with Jobs

  storyMedia StoryMedia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Media {
  IMG
  VIDEO
  COMBINED
}

model StoryMedia {
  id      String @id @default(uuid())
  storyId String

  mediaUrl  String
  cloudId   String
  mediaType Media
  order     Int    @default(0)

  duration Int @default(3) // Only for video, for image it will be 0

  storyViews StoryViews[]
  likes      Likes[]

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model StoryViews {
  id String @id @default(uuid())

  storyMediaId String
  storyMedia   StoryMedia @relation(fields: [storyMediaId], references: [id], onDelete: Cascade)

  viewerId String
  viewer   Profile @relation(fields: [viewerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storyMediaId, viewerId]) // To prevent multiple views marking
}

model Likes {
  id String @id @default(uuid())

  profileId String 
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  postId String?
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)

  reelId String?
  reel   Reel?   @relation(fields: [reelId], references: [id], onDelete: Cascade)

  storyMediaId String?
  storyMedia   StoryMedia? @relation(fields: [storyMediaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([profileId, postId])
  @@unique([profileId, reelId])
  @@unique([profileId, storyMediaId])
}

model Comments {
  id String @id @default(uuid())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  postId String?
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)

  reelId String?
  reel   Reel?   @relation(fields: [reelId], references: [id], onDelete: Cascade)

  replies Comments[] @relation("CommentToComment") // to handle reply 

  parentId String?
  parentComment Comments? @relation("CommentToComment",fields: [parentId], references: [id], onDelete: Cascade)

  content String

  createdAt DateTime @default(now())
}

enum Purpose {
  LIKE
  COMMENT
  MESSAGE // Later messaging with websocket to be done
  FOLLOW
}

model Notification {
  id String @id @default(uuid())

  receiverId String
  senderId   String

  receiver Profile @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender   Profile @relation("Sender", fields: [senderId], references: [id])

  purpose Purpose
  message String

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([receiverId])
  @@index([senderId])
}

enum JobName {
  STORY
  POST
}
enum JobStatus {
  PROGRESS
  SUCCESS
  FAILED
}
model Job {
  id String @id @default(uuid())

  jobId String
  name JobName
  status JobStatus

  userId String
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}