// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id      String    @id @default(uuid())
  profile Profile[] // is 0-Many

  email    String @unique
  username String @db.VarChar(200)
  password String @db.VarChar(255)
  role     Role   @default(USER)

  // Also add enum of :role:

  isEmailVerified Boolean @default(false)
  isActive        Boolean @default(false) // Later shall be removed => To let user use from different browsers at the same time
  tokenVersion    Int     @default(0)

  passResetToken   String? // Shall be removed
  passResetExpTime DateTime? // Shall be removed

  jobs Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Profile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  name     String  @unique
  isActive Boolean @default(false)

  bio       String?
  avatarUrl String? // Later changed to required
  cloudId   String?

  isPrivate Boolean @default(false)

  posts         Post[]
  story         Story?
  reels         Reel[]
  savedPosts    SavePost[]
  storiesViewed StoryViews[]

  receivedNotifications Notification[] @relation("Receiver")

  followers  Follow[] @relation("followers")
  followings Follow[] @relation("followings")

  pofileLikes      Likes[]
  profileCommentes Comments[]

  chat    Chat[]        @relation("ProfileChats")
  admin   Chat[]        @relation("ChatCreator")
  message Message[]
  msgView MessageView[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Follow {
  id String @id @default(uuid())

  followerId  String
  followingId String

  createdAt DateTime @default(now())

  follower  Profile @relation("followings", fields: [followerId], references: [id])
  following Profile @relation("followers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Post {
  id String @id @default(uuid())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  isReady Boolean @default(false) // Later me removed

  caption     String
  description String?
  postPhoto   PostMedia[]

  notify Notification[] @relation("PostNotify")

  likes    Likes[]
  comments Comments[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostMedia {
  id     String @id @default(uuid())
  postId String

  mediaUrl String
  cloudId  String

  savedPosts SavePost[]

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model SavePost {
  id          String @id @default(uuid())
  postMediaId String

  profileId String // It will be the id of the user who saves

  post    PostMedia @relation(fields: [postMediaId], references: [id], onDelete: Cascade)
  profile Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Reel {
  id String @id @default(uuid())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id])

  videoUrl String
  cloudId  String
  caption  String?

  likes    Likes[]
  comments Comments[]

  notify Notification[] @relation("ReelNotify")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Story {
  id String @id @default(uuid())

  profileId String  @unique
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  isReady   Boolean  @default(false) // Later be removed => And have One to Many with Jobs

  storyMedia StoryMedia[]

  notify Notification[] @relation("StoryNotify")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Media {
  IMG
  VIDEO
  COMBINED
}

model StoryMedia {
  id      String @id @default(uuid())
  storyId String

  mediaUrl  String
  cloudId   String
  mediaType Media
  order     Int    @default(0)

  duration Int @default(3) // Only for video, for image it will be 0

  storyViews StoryViews[]
  likes      Likes[]

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model StoryViews {
  id String @id @default(uuid())

  storyMediaId String
  storyMedia   StoryMedia @relation(fields: [storyMediaId], references: [id], onDelete: Cascade)

  viewerId String
  viewer   Profile @relation(fields: [viewerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storyMediaId, viewerId]) // To prevent multiple views marking
}

model Likes {
  id String @id @default(uuid())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  postId String?
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)

  reelId String?
  reel   Reel?   @relation(fields: [reelId], references: [id], onDelete: Cascade)

  storyMediaId String?
  storyMedia   StoryMedia? @relation(fields: [storyMediaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([profileId, postId])
  @@unique([profileId, reelId])
  @@unique([profileId, storyMediaId])
}

model Comments {
  id String @id @default(uuid())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  postId String?
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)

  reelId String?
  reel   Reel?   @relation(fields: [reelId], references: [id], onDelete: Cascade)

  replies Comments[] @relation("CommentToComment") // to handle reply 

  parentId      String?
  parentComment Comments? @relation("CommentToComment", fields: [parentId], references: [id], onDelete: Cascade)

  content String

  createdAt DateTime @default(now())
}

enum Purpose {
  COMMENT
  MESSAGE
  POST
  REEL
  STORY
  CHAT
}

model Notification {
  id String @id @default(uuid())

  receiverId String

  receiver Profile @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  // This 2 below only would be sent to client with notification
  purpose Purpose
  content String

  isApproved Boolean?

  // After making them as isRead true => these id would be sent in return 
  storyId String?
  postId String?
  reelId String?
  chatId String?
  messageId String?

  story Story? @relation("StoryNotify", fields: [storyId], references: [id], onDelete: Cascade)
  post Post? @relation("PostNotify", fields: [postId], references: [id], onDelete: Cascade)
  reel Reel? @relation("ReelNotify", fields: [reelId], references: [id], onDelete: Cascade)
  chat Chat? @relation("NewChatNotify", fields: [chatId], references: [id], onDelete: Cascade)
  message Message? @relation("NewMessageNotify", fields: [messageId], references: [id], onDelete: Cascade)


  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([receiverId])
}

enum JobName {
  STORY
  POST
}

enum JobStatus {
  PROGRESS
  SUCCESS
  FAILED
}

model Job {
  id String @id @default(uuid())

  jobId  String
  name   JobName
  status JobStatus

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Chat {
  id String @id @default(uuid())

  name     String?
  mediaUrl String?
  cloudId  String?

  profiles Profile[] @relation("ProfileChats")
  creatorId  String // This could easily handle in both private and group chat
  creator    Profile  @relation("ChatCreator", fields: [creatorId], references: [id])

  isApproved Boolean? @default(false)
  isGroup    Boolean  @default(false)

  notify Notification[] @relation("NewChatNotify")

  message   Message[]
  createdAt DateTime  @default(now())
}

enum Format {
  TEXT
  FILE
  VIDEO
  GIF
  IMAGE
}

model Message {
  id String @id @default(uuid())

  format   Format  @default(TEXT)
  content  String?
  mediaUrl String?
  cloudId  String?

  senderId String
  sender   Profile @relation(fields: [senderId], references: [id])

  replyId String?
  reply   Message?  @relation("MessageReply", fields: [replyId], references: [id])
  replyTo Message[] @relation("MessageReply")

  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id])

  notify Notification[] @relation("NewMessageNotify")

  msgView MessageView[]

  @@index([chatId])
}

model MessageView {
  id        String   @id @default(uuid())
  profileId String
  msgId     String
  profile   Profile  @relation(fields: [profileId], references: [id])
  message   Message  @relation(fields: [msgId], references: [id])
  viewedAt  DateTime @default(now())

  @@unique([msgId, profileId])
}
